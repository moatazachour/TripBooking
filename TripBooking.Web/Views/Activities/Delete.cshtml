@using TripBooking.Web.Models.Entities
@model Activity

@{
    ViewData["Title"] = "Delete Activity";
}

<h1>Delete Activity</h1>

<p>Are you sure you want to delete this activity?</p>

<dl class="row">
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Description</dd>

    <dt class="col-sm-2">Unit Price</dt>
    <dd class="col-sm-10">@Model.UnitPrice.ToString("C")</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="ActivityId" />
    <confirm-button confirm-message="Delete this activity permanently?" class="btn btn-danger">Delete</confirm-button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>